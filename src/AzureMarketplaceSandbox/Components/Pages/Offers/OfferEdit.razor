@page "/offers/{OfferId}"
@rendermode InteractiveServer
@inject MarketplaceDbContext Db
@inject NavigationManager Nav

<PageTitle>Edit Offer - @OfferId</PageTitle>

@if (_offer is null)
{
    <p>Offer not found.</p>
}
else
{
    <h1>Offer: @_offer.OfferId</h1>
    <p><strong>Publisher:</strong> @_offer.PublisherId | <strong>Display Name:</strong> @_offer.DisplayName | <strong>Currency:</strong> @_offer.Currency</p>

    <hr />
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="mb-0">Plans</h4>
        <button class="btn btn-primary btn-sm" @onclick="OpenAddPlanModal">Add Plan</button>
    </div>

    @if (_offer.Plans.Count == 0)
    {
        <p class="text-muted">No plans yet.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Plan ID</th>
                    <th>Display Name</th>
                    <th>Price</th>
                    <th>Billing</th>
                    <th>Term</th>
                    <th>Per Seat</th>
                    <th>Min/Max Qty</th>
                    <th>Dimensions</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var plan in _offer.Plans)
                {
                    <tr>
                        <td>@plan.PlanId</td>
                        <td>@plan.DisplayName</td>
                        <td>@plan.Price @_offer.Currency</td>
                        <td>@plan.BillingTermUnit</td>
                        <td>@plan.SubscriptionTermUnit</td>
                        <td>@(plan.IsPricePerSeat ? "Yes" : "No")</td>
                        <td>@(plan.IsPricePerSeat ? $"{plan.MinQuantity} - {plan.MaxQuantity}" : "-")</td>
                        <td>@plan.PlanMeteringDimensions.Count</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenEditPlanModal(plan)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePlan(plan)">Remove</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <hr />
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <h4 class="mb-0">Metering Dimensions</h4>
            <small class="text-muted">Dimensions are defined at offer level and assigned to plans below.</small>
        </div>
        <button class="btn btn-primary btn-sm" @onclick="OpenAddDimensionModal">Add Dimension</button>
    </div>

    @if (_offer.MeteringDimensions.Count == 0)
    {
        <p class="text-muted">No dimensions yet.</p>
    }
    else
    {
        <table class="table table-sm mt-3">
            <thead>
                <tr>
                    <th>Dimension ID</th>
                    <th>Display Name</th>
                    <th>Unit</th>
                    <th>Price/Unit</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dim in _offer.MeteringDimensions)
                {
                    <tr>
                        <td>@dim.DimensionId</td>
                        <td>@dim.DisplayName</td>
                        <td>@dim.UnitOfMeasure</td>
                        <td>@dim.PricePerUnit @_offer.Currency</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenEditDimensionModal(dim)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveDimension(dim)">Remove</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_offer.Plans.Count > 0 && _offer.MeteringDimensions.Count > 0)
    {
        <hr />
        <h4>Dimension Assignment per Plan</h4>
        <p class="text-muted">Select which dimensions are available for each plan and set the included quantity.</p>

        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Dimension</th>
                    @foreach (var plan in _offer.Plans)
                    {
                        <th class="text-center">@plan.PlanId</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var dim in _offer.MeteringDimensions)
                {
                    <tr>
                        <td>@dim.DimensionId (@dim.DisplayName)</td>
                        @foreach (var plan in _offer.Plans)
                        {
                            var pmd = plan.PlanMeteringDimensions.FirstOrDefault(p => p.MeteringDimensionId == dim.Id);
                            var isAssigned = pmd is not null;
                            <td class="text-center">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                    <input type="checkbox" checked="@isAssigned"
                                           @onchange="(e) => ToggleDimensionAssignment(plan, dim, (bool)e.Value!)" />
                                    @if (isAssigned)
                                    {
                                        var capturedPmd = pmd!;
                                        <input type="number" step="any" class="form-control form-control-sm" style="width: 80px;"
                                               value="@capturedPmd.IncludedQuantity"
                                               @onchange="(e) => UpdateIncludedQuantity(plan, dim, decimal.TryParse(e.Value?.ToString(), out var v) ? v : 0)"
                                               placeholder="Incl." />
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a href="offers" class="btn btn-outline-secondary">Back to Offers</a>
    </div>

    @if (_editingPlan is not null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(_isNewPlan ? "Add Plan" : "Edit Plan")</h5>
                        <button type="button" class="btn-close" @onclick="ClosePlanModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Plan ID</label>
                                <InputText class="form-control" @bind-Value="_editingPlan.PlanId" disabled="@(!_isNewPlan)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Display Name</label>
                                <InputText class="form-control" @bind-Value="_editingPlan.DisplayName" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Price</label>
                                <InputNumber class="form-control" @bind-Value="_editingPlan.Price" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Billing Term</label>
                                <InputSelect class="form-control" @bind-Value="_editingPlan.BillingTermUnit">
                                    <option value="P1M">P1M</option>
                                    <option value="P1Y">P1Y</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Subscription Term</label>
                                <InputText class="form-control" @bind-Value="_editingPlan.SubscriptionTermUnit" placeholder="e.g. P3M, P1Y" />
                            </div>
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    <InputCheckbox class="form-check-input" @bind-Value="_editingPlan.IsPricePerSeat" />
                                    <label class="form-check-label">Per Seat</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Min Qty</label>
                                <InputNumber class="form-control" @bind-Value="_editingPlan.MinQuantity" disabled="@(!_editingPlan.IsPricePerSeat)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Max Qty</label>
                                <InputNumber class="form-control" @bind-Value="_editingPlan.MaxQuantity" disabled="@(!_editingPlan.IsPricePerSeat)" />
                            </div>
                        </div>
                        @if (_planError is not null)
                        {
                            <div class="alert alert-danger mt-3 mb-0">@_planError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="ClosePlanModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SavePlan">@(_isNewPlan ? "Add Plan" : "Save")</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_editingDimension is not null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(_isNewDimension ? "Add Metering Dimension" : "Edit Metering Dimension")</h5>
                        <button type="button" class="btn-close" @onclick="CloseDimensionModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Dimension ID</label>
                                <InputText class="form-control" @bind-Value="_editingDimension.DimensionId" disabled="@(!_isNewDimension)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Display Name</label>
                                <InputText class="form-control" @bind-Value="_editingDimension.DisplayName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Unit of Measure</label>
                                <InputText class="form-control" @bind-Value="_editingDimension.UnitOfMeasure" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Price/Unit</label>
                                <InputNumber class="form-control" @bind-Value="_editingDimension.PricePerUnit" />
                            </div>
                        </div>
                        @if (_dimError is not null)
                        {
                            <div class="alert alert-danger mt-3 mb-0">@_dimError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseDimensionModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveDimension">@(_isNewDimension ? "Add" : "Save")</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string OfferId { get; set; } = string.Empty;

    private Offer? _offer;
    private Plan? _editingPlan;
    private bool _isNewPlan;
    private MeteringDimension? _editingDimension;
    private bool _isNewDimension;
    private string? _planError, _dimError;

    protected override async Task OnInitializedAsync()
    {
        await LoadOffer();
    }

    private async Task LoadOffer()
    {
        _offer = await Db.Offers
            .Include(o => o.Plans)
                .ThenInclude(p => p.PlanMeteringDimensions)
            .Include(o => o.MeteringDimensions)
            .FirstOrDefaultAsync(o => o.OfferId == OfferId);
    }

    private static readonly System.Text.RegularExpressions.Regex TermUnitPattern = new(@"^P(\d+)([MY])$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    private void OpenAddPlanModal()
    {
        _editingPlan = new Plan
        {
            BillingTermUnit = "P1M",
            SubscriptionTermUnit = "P1M"
        };
        _isNewPlan = true;
        _planError = null;
    }

    private void OpenEditPlanModal(Plan plan)
    {
        _editingPlan = new Plan
        {
            Id = plan.Id,
            PlanId = plan.PlanId,
            DisplayName = plan.DisplayName,
            Description = plan.Description,
            Price = plan.Price,
            BillingTermUnit = plan.BillingTermUnit,
            SubscriptionTermUnit = plan.SubscriptionTermUnit,
            MinQuantity = plan.MinQuantity,
            MaxQuantity = plan.MaxQuantity,
            IsPricePerSeat = plan.IsPricePerSeat,
            IsPrivate = plan.IsPrivate,
            HasFreeTrials = plan.HasFreeTrials,
            IsStopSell = plan.IsStopSell,
            Market = plan.Market,
            TermDescription = plan.TermDescription
        };
        _isNewPlan = false;
        _planError = null;
    }

    private void ClosePlanModal()
    {
        _editingPlan = null;
        _planError = null;
    }

    private async Task SavePlan()
    {
        if (_editingPlan is null) return;

        _planError = null;
        if (string.IsNullOrWhiteSpace(_editingPlan.PlanId))
        {
            _planError = "Plan ID is required.";
            return;
        }
        if (_editingPlan.BillingTermUnit is not "P1M" and not "P1Y")
        {
            _planError = "Billing Term must be P1M or P1Y.";
            return;
        }
        var termMatch = TermUnitPattern.Match(_editingPlan.SubscriptionTermUnit);
        if (!termMatch.Success)
        {
            _planError = "Subscription Term must match format P{amount}{M|Y}, e.g. P3M, P1Y.";
            return;
        }
        var billingUnit = _editingPlan.BillingTermUnit.EndsWith("Y", StringComparison.OrdinalIgnoreCase) ? "Y" : "M";
        var termUnit = termMatch.Groups[2].Value.ToUpperInvariant();
        if (billingUnit != termUnit)
        {
            _planError = "Subscription Term must use the same base unit (M/Y) as Billing Term.";
            return;
        }

        if (_isNewPlan)
        {
            _editingPlan.Offer = _offer!;
            Db.Plans.Add(_editingPlan);
        }
        else
        {
            var existing = await Db.Plans.FirstOrDefaultAsync(p => p.Id == _editingPlan.Id);
            if (existing is null)
            {
                _planError = "Plan no longer exists.";
                return;
            }
            existing.DisplayName = _editingPlan.DisplayName;
            existing.Price = _editingPlan.Price;
            existing.BillingTermUnit = _editingPlan.BillingTermUnit;
            existing.SubscriptionTermUnit = _editingPlan.SubscriptionTermUnit;
            existing.MinQuantity = _editingPlan.MinQuantity;
            existing.MaxQuantity = _editingPlan.MaxQuantity;
            existing.IsPricePerSeat = _editingPlan.IsPricePerSeat;
        }

        await Db.SaveChangesAsync();
        _editingPlan = null;
        await LoadOffer();
    }

    private async Task RemovePlan(Plan plan)
    {
        Db.Plans.Remove(plan);
        await Db.SaveChangesAsync();
        await LoadOffer();
    }

    private void OpenAddDimensionModal()
    {
        _editingDimension = new MeteringDimension();
        _isNewDimension = true;
        _dimError = null;
    }

    private void OpenEditDimensionModal(MeteringDimension dim)
    {
        _editingDimension = new MeteringDimension
        {
            Id = dim.Id,
            DimensionId = dim.DimensionId,
            DisplayName = dim.DisplayName,
            UnitOfMeasure = dim.UnitOfMeasure,
            PricePerUnit = dim.PricePerUnit
        };
        _isNewDimension = false;
        _dimError = null;
    }

    private void CloseDimensionModal()
    {
        _editingDimension = null;
        _dimError = null;
    }

    private async Task SaveDimension()
    {
        if (_editingDimension is null) return;

        _dimError = null;
        if (string.IsNullOrWhiteSpace(_editingDimension.DimensionId))
        {
            _dimError = "Dimension ID is required.";
            return;
        }

        if (_isNewDimension)
        {
            _editingDimension.Offer = _offer!;
            Db.MeteringDimensions.Add(_editingDimension);
        }
        else
        {
            var existing = await Db.MeteringDimensions.FirstOrDefaultAsync(d => d.Id == _editingDimension.Id);
            if (existing is null)
            {
                _dimError = "Dimension no longer exists.";
                return;
            }
            existing.DisplayName = _editingDimension.DisplayName;
            existing.UnitOfMeasure = _editingDimension.UnitOfMeasure;
            existing.PricePerUnit = _editingDimension.PricePerUnit;
        }

        await Db.SaveChangesAsync();
        _editingDimension = null;
        await LoadOffer();
    }

    private async Task RemoveDimension(MeteringDimension dim)
    {
        Db.MeteringDimensions.Remove(dim);
        await Db.SaveChangesAsync();
        await LoadOffer();
    }

    private async Task ToggleDimensionAssignment(Plan plan, MeteringDimension dim, bool assign)
    {
        if (assign)
        {
            Db.PlanMeteringDimensions.Add(new PlanMeteringDimension
            {
                PlanId = plan.Id,
                MeteringDimensionId = dim.Id
            });
        }
        else
        {
            var existing = await Db.PlanMeteringDimensions
                .FirstOrDefaultAsync(pmd => pmd.PlanId == plan.Id && pmd.MeteringDimensionId == dim.Id);
            if (existing is not null)
                Db.PlanMeteringDimensions.Remove(existing);
        }
        await Db.SaveChangesAsync();
        await LoadOffer();
    }

    private async Task UpdateIncludedQuantity(Plan plan, MeteringDimension dim, decimal quantity)
    {
        var existing = await Db.PlanMeteringDimensions
            .FirstOrDefaultAsync(pmd => pmd.PlanId == plan.Id && pmd.MeteringDimensionId == dim.Id);
        if (existing is not null)
        {
            existing.IncludedQuantity = quantity;
            await Db.SaveChangesAsync();
            await LoadOffer();
        }
    }
}
