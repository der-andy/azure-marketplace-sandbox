@page "/settings"
@rendermode InteractiveServer
@inject TenantService TenantService

<PageTitle>Settings</PageTitle>

<h1>Tenant Settings</h1>

@if (_tenant is null)
{
    <p>Loading...</p>
}
else
{
    <div class="card mb-4">
        <div class="card-header">Identity</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Display name</dt>
                <dd class="col-sm-9">@_tenant.DisplayName</dd>

                <dt class="col-sm-3">User principal name</dt>
                <dd class="col-sm-9">@(_tenant.UserPrincipalName ?? "—")</dd>

                <dt class="col-sm-3">Entra Object ID</dt>
                <dd class="col-sm-9"><code>@_tenant.EntraObjectId</code></dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@_tenant.CreatedAt.ToString("yyyy-MMM-dd HH:mm:ss") UTC</dd>

                <dt class="col-sm-3">Last login</dt>
                <dd class="col-sm-9">@_tenant.LastLoginAt.ToString("yyyy-MMM-dd HH:mm:ss") UTC</dd>
            </dl>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">Configuration</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Publisher ID</label>
                <input class="form-control" @bind="_publisherIdInput" />
                <div class="form-text">
                    Default <code>publisherId</code> for newly seeded offers. Changing this does not update existing offers.
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Webhook URL</label>
                <input class="form-control" @bind="_webhookUrlInput" placeholder="https://your-app.example.com/api/webhook" />
                <div class="form-text">
                    Destination for webhook deliveries triggered by subscription lifecycle events.
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Landing Page URL</label>
                <input class="form-control" @bind="_landingPageUrlInput" placeholder="https://your-app.example.com/landing" />
                <div class="form-text">
                    Base URL used when generating simulated marketplace landing links.
                </div>
            </div>

            <button class="btn btn-primary" @onclick="SaveConfiguration" disabled="@_saving">
                @(_saving ? "Saving..." : "Save")
            </button>
            @if (_saved)
            {
                <span class="text-success small ms-3">Saved.</span>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">API Bearer Token</div>
        <div class="card-body">
            <p class="text-muted small">
                Required for calls to <code>/api/saas/*</code> and <code>/api/usageEvent</code>.
                Regenerating the token immediately invalidates the previous one.
            </p>
            <div class="input-group mb-2">
                <input class="form-control font-monospace"
                       type="@(_tokenRevealed ? "text" : "password")"
                       value="@_tenant.ApiBearerToken"
                       readonly />
                <button class="btn btn-outline-secondary" @onclick="ToggleReveal">
                    @(_tokenRevealed ? "Hide" : "Reveal")
                </button>
                <button class="btn btn-outline-danger" @onclick="RegenerateToken" disabled="@_regenerating">
                    @(_regenerating ? "Regenerating..." : "Regenerate")
                </button>
            </div>
            @if (_regenerated)
            {
                <div class="alert alert-warning mb-0">
                    New token issued. Update all integrations — the previous token is no longer accepted.
                </div>
            }
        </div>
    </div>
}

@code {
    private Tenant? _tenant;
    private string _publisherIdInput = string.Empty;
    private string _webhookUrlInput = string.Empty;
    private string _landingPageUrlInput = string.Empty;
    private bool _saved;
    private bool _saving;
    private bool _tokenRevealed;
    private bool _regenerating;
    private bool _regenerated;

    protected override async Task OnInitializedAsync()
    {
        _tenant = await TenantService.GetCurrentAsync();
        _publisherIdInput = _tenant?.PublisherId ?? string.Empty;
        _webhookUrlInput = _tenant?.WebhookUrl ?? string.Empty;
        _landingPageUrlInput = _tenant?.LandingPageUrl ?? string.Empty;
    }

    private async Task SaveConfiguration()
    {
        if (_tenant is null || string.IsNullOrWhiteSpace(_publisherIdInput)) return;
        _saving = true;
        _saved = false;
        await TenantService.UpdateConfigurationAsync(_publisherIdInput, _webhookUrlInput, _landingPageUrlInput);
        _tenant = await TenantService.GetCurrentAsync();
        _saving = false;
        _saved = true;
    }

    private void ToggleReveal()
    {
        _tokenRevealed = !_tokenRevealed;
    }

    private async Task RegenerateToken()
    {
        _regenerating = true;
        _regenerated = false;
        await TenantService.RegenerateApiBearerTokenAsync();
        _tenant = await TenantService.GetCurrentAsync();
        _tokenRevealed = true;
        _regenerating = false;
        _regenerated = true;
    }
}
